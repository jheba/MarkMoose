{
  "name": "markmoose",
  "version": "1.3.1",
  "description": "MarkMoose — A desktop Markdown viewer and editor",
  "main": "src/main.js",
  "author": "Morten Rasmussen",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:portable": "npm run build:renderer && electron-builder --win portable",
    "build:appx": "npm run build:renderer && electron-builder --win appx"
  },
  "build": {
    "appId": "com.mortenrasmussen.markmoose",
    "productName": "MarkMoose",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/main.js",
      "src/preload.js",
      "src/splash.html",
      "dist/**/*",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "build-resources",
        "to": "build-resources"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build-resources/icon.ico",
      "fileAssociations": [
        {
          "ext": "md",
          "name": "Markdown File",
          "description": "Markdown Document",
          "role": "Viewer",
          "icon": "build-resources/md-icon.ico"
        },
        {
          "ext": "markdown",
          "name": "Markdown File",
          "description": "Markdown Document",
          "role": "Viewer",
          "icon": "build-resources/md-icon.ico"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "MarkMoose-Portable.exe"
    },
    "asarUnpack": [],
    "electronLanguages": ["en-US"],
    "afterPack": "./scripts/afterPack.js",
    "appx": {
      "identityName": "MortenRasmussen.MarkMoose",
      "publisher": "CN=BFCE2BEF-1A0C-48E0-8EB6-E00EF06863D8",
      "publisherDisplayName": "Morten Rasmussen",
      "displayName": "MarkMoose Markdown Editor",
      "applicationId": "MarkMoose",
      "backgroundColor": "#fafaf8",
      "languages": ["en-US"]
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.5",
    "vite": "^5.4.3",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "mermaid": "^11.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
